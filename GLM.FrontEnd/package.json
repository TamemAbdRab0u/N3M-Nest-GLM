{
  "name": "glm-frontend",
  "private": true,
  "devDependencies": {
    "@microsoft/signalr": "7.0.5",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "tailwindcss": "^3.4.7"
  },
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i ./tailwind.input.css -o ./Assets/tailwind.css --minify",
    "build:signalr": "node ./scripts/copy-signalr.js",
    "watch:css": "tailwindcss -c tailwind.config.js -i ./tailwind.input.css -o ./Assets/tailwind.css --watch"
  }
}
